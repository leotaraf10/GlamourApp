{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/products/:id", "destination": "/api/products?id=:id" },
    { "source": "/api/orders/:id/status", "destination": "/api/orders?id=:id" },
    { "source": "/api/orders/:id", "destination": "/api/orders?id=:id" },
    { "source": "/api/reviews/:id", "destination": "/api/reviews?product_id=:id" },
    { "source": "/api/hero-slides/:id", "destination": "/api/hero-slides?id=:id" },
    { "source": "/api/home-sections/:id", "destination": "/api/home-sections?id=:id" },
    { "source": "/api/admin/nav-categories/:id", "destination": "/api/categories?id=:id" },
    { "source": "/api/admin/nav-categories", "destination": "/api/categories" },
    { "source": "/api/admin/reviews", "destination": "/api/reviews" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
